@{
    ViewData["Title"] = "تعيين كلمة مرور جديدة";
    var modelErrors = ViewData.ModelState.Values
        .SelectMany(v => v.Errors)
        .Select(e => e.ErrorMessage)
        .Where(m => !string.IsNullOrWhiteSpace(m))
        .ToList();
    var token = ViewBag.Token as string ?? string.Empty;
}
@section Styles {
    <link rel="stylesheet" href="~/css/Auth/resetPassword.css" />
}
@section Scripts {
    <script src="~/js/Auth/resetPassword.js"></script>
}

<div id="errorPopupOverlay" class="popup-overlay @(modelErrors.Any() ? "active" : "")">
    <div class="popup-card popup-error">
        <div class="popup-icon-ring">
            <i class="fa-solid fa-triangle-exclamation"></i>
        </div>
        <h3 class="popup-title">تعذر تغيير كلمة المرور</h3>
        <ul class="popup-error-list">
            @foreach (var err in modelErrors)
            {
                <li><i class="fa-solid fa-circle-dot"></i> @err</li>
            }
        </ul>
        <button class="popup-close-btn" onclick="closeErrorPopup()">
            <i class="fa-solid fa-xmark"></i>
        </button>
    </div>
</div>

<div class="reset-box">
    <div class="reset">
        <h2 class="form-title">تعيين كلمة مرور جديدة</h2>
        <p class="form-subtitle">اختر كلمة مرور قوية لحماية حسابك.</p>
    </div>

    <div class="reset-form-wrapper">
        <form id="resetForm"
              asp-area="Identity"
              asp-controller="Login"
              asp-action="ResetPassword"
              method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" name="token" value="@token" />

            <div class="password-group">
                <div class="input-group">
                    <label for="password">كلمة المرور الجديدة</label>
                    <div class="input-wrapper password-wrapper">
                        <input type="password" id="password" name="password"
                               placeholder="كلمة المرور" required minlength="8" maxlength="128" />
                        <i class="fa-solid fa-eye toggle-password" id="togglePassword"></i>
                    </div>

                    <div id="passwordStrength" class="password-strength" style="display:none; margin-bottom:12px;">
                        <div class="strength-bar"><span id="strengthFill"></span></div>
                        <span id="strengthLabel" style="font-size:12px;font-weight:600;"></span>
                    </div>

                    <label for="confirmPassword">تأكيد كلمة المرور</label>
                    <div class="input-wrapper password-wrapper">
                        <input type="password" id="confirmPassword" name="confirmPassword"
                               placeholder="تأكيد كلمة المرور" required minlength="8" maxlength="128" />
                        <i class="fa-solid fa-eye toggle-password" id="toggleConfirmPassword"></i>
                    </div>
                </div>
            </div>

            <button type="submit" class="submit-btn">تعيين كلمة مرور جديدة</button>
        </form>

        <div class="login-link">
            <a asp-area="Identity" asp-controller="Login" asp-action="Login">
                تذكرت كلمة المرور؟ سجّل الدخول
            </a>
        </div>
    </div>
</div>

<script>
    function closeErrorPopup() {
        document.getElementById('errorPopupOverlay').classList.remove('active');
    }
    document.getElementById('errorPopupOverlay')?.addEventListener('click', function (e) {
        if (e.target === this) closeErrorPopup();
    });
</script>
