@*
    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@

@{
    ViewData["Title"] = "طلب زيارة";
    var providers = Model?.Providers ?? new List<Ziarah.Areas.Guest.Models.ProviderCardViewModel>();
    var specializations = Model?.Specializations ?? new List<string>();
}
 @section Styles {
    <link rel="stylesheet" href="~/css/Guest/requestVisit.css" />
}
@section Scripts {
    <script src="~/js/Guest/requestVisit.js"></script>
}
<section class="visit-hero">
    <div class="hero-illustration">
        <img src="~/assets/image/hero-req-visit.png" alt="طلب زيارة">
    </div>
    <div class="hero-overlay"></div>
    <div class="hero-content">
        <h1>طلب زيارة منزلية</h1>
        <div class="line"></div>
        <p>احصل على الرعاية الصحية في منزلك على يد نخبة من الأطباء والممرضين المتخصصين</p>
    </div>
</section>

<main class="visit-main">

    <div class="filter-section">
        <div class="visit-type-tabs">
            <button class="visit-type-btn active">
                <i class="fa-solid fa-user-doctor"></i>
                <span>طبيب</span>
            </button>
            <button class="visit-type-btn">
                <i class="fa-solid fa-user-nurse"></i>
                <span>تمريض</span>
            </button>
        </div>
    </div>

    <div class="filter-section" id="filterArea">
        <div class="filter-grid">
            <div class="filter-item">
                <label>الاسم</label>
                <input type="text" id="filterName" placeholder="ابحث بالاسم...">
            </div>
            <div class="filter-item">
                <label> العنوان</label>
                <input type="text" id="filterAddress" placeholder="المنطقة أو الحي...">
            </div>
            <div class="filter-item" id="specFilter">
                <label> التخصص</label>
                <div class="custom-select-wrapper">
                    <select id="filterSpec" class="custom-select">
                        <option value="">كل التخصصات</option>
                        @foreach (var spec in specializations)
                        {
                            <option value="@spec">@spec</option>
                        }
                    </select>
                </div>
            </div>
            <div class="filter-item">
                <label>التقييم</label>
                <div class="custom-select-wrapper">
                    <select id="filterRating" class="custom-select">
                        <option value="">كل التقييمات</option>
                        <option value="5">5 نجوم فقط</option>
                        <option value="4">4 نجوم فأكثر</option>
                        <option value="3">3 نجوم فأكثر</option>
                        <option value="2">2 نجوم فأكثر</option>
                    </select>
                </div>
            </div>
            <div class="filter-item">
                <label>حدد اعلي السعر</label>
                <div class="price-range-wrap">
                    <input type="range" id="filterPrice" min="100" max="1000" step="50" value="1000" oninput="updatePriceLabel(); applyFilters()">
                    <span id="priceLabel">حتى 1000 جنيه</span>
                </div>
            </div>
            <div class="filter-item filter-reset-wrap">
                <button class="reset-btn">
                    <i class="fa-solid fa-rotate-right"></i> 
                </button>
            </div>
        </div>
    </div>

    <div class="results-meta">
        <div class="results-count">
            عرض <span id="visibleCount">0</span> من <span id="totalCount">@providers.Count</span> نتيجة
        </div>
    </div>

    <div class="cards-grid" id="cardsGrid">
        @foreach (var provider in providers)
        {
            var titlePrefix = provider.Type == "doctor" ? "د." : "أ.";
            var displayName = $"{titlePrefix} {provider.Name}";
            var actionLabel = provider.Type == "doctor" ? "طلب طبيب" : "طلب ممرض";
            var ratingText = provider.Rating > 0 ? provider.Rating.ToString("0.0") : "0.0";
            var priceText = provider.Price > 0 ? $"{provider.Price:0} جنيه" : "غير محدد";

            <div class="provider-card"
                 data-id="@provider.Id"
                 data-type="@provider.Type"
                 data-name="@displayName"
                 data-spec="@provider.Spec"
                 data-price="@provider.Price"
                 data-rating="@provider.Rating"
                 data-img="@provider.ImageUrl"
                 data-has-photo="@provider.HasCustomPhoto.ToString().ToLowerInvariant()">
                <div class="provider-img">
                    @if (provider.HasCustomPhoto)
                    {
                        <img src="@provider.ImageUrl" alt="@displayName">
                    }
                    else
                    {
                        <div class="provider-avatar-fallback @(provider.Type == "doctor" ? "doctor" : "nurse")">
                            <i class="fa-solid @(provider.Type == "doctor" ? "fa-user-doctor" : "fa-user-nurse")"></i>
                        </div>
                    }
                    <span class="provider-rating-badge">
                        <i class="fa-solid fa-star"></i> @ratingText
                    </span>
                </div>
                <div class="provider-card-body">
                    <div class="provider-name">@displayName</div>
                    <div class="provider-spec">@provider.Spec</div>
                    <div class="provider-price">
                        <i class="fa-solid fa-briefcase-medical"></i>
                        سعر الكشف: <span>@priceText</span>
                    </div>
                </div>
                <div class="provider-card-footer">
                    <button class="book-btn" onclick="openBookingModal(this)">@actionLabel</button>
                    <a href="@provider.ProfileUrl" class="more-btn">المزيد</a>
                </div>
            </div>
        }
    </div>

    <div class="empty-state" id="emptyState">
        <i class="fa-solid fa-user-doctor"></i>
        <h3>لا توجد نتائج</h3>
        <p>جرب تغيير مدخلاتك</p>
    </div>
    <div class="pagination-wrap" id="paginationWrap"></div>

</main>

<div class="overlay" id="bookingOverlay" onclick="closeBookingIfOutside(event)">
    <div class="booking-modal">
        <div class="booking-modal-header">
            <div class="booking-modal-title">
                طلب زيارة
            </div>
            <button class="booking-close-btn" onclick="closeBookingModal()">
                <i class="fa-solid fa-xmark"></i>
            </button>

        </div>

        <div class="booking-provider-info" id="bookingDoctorInfo">
            <div class="booking-provider-img">
                <img src="~/assets/image/mohamed.png" alt="">
            </div>
            <div>
                <div class="booking-provider-name">محمد احمد</div>
                <div class="booking-provider-spec">عظام</div>
                <div class="booking-provider-price">سعر الكشف 500 جنيه</div>
            </div>
        </div>

        <form id="bookingForm"
              asp-area="Guest"
              asp-controller="RequestVisit"
              asp-action="SubmitVisit"
              method="post"
              enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            <input type="hidden" name="ProviderId" id="bookingProviderId" value="0" />
            <input type="hidden" name="ProviderType" id="bookingVisitType" value="doctor" />
            <div class="double-input">
                <div class="input-group">
                    <label>الاسم بالكامل</label>
                    <input type="text" name="FullName" placeholder="" required maxlength="200" />
                </div>
                <div class="input-group">
                    <label>رقم الهاتف للتواصل</label>
                    <input type="text" name="Phone" placeholder="01xxxxxxxxx" required pattern="^01[0125][0-9]{8}$" title="رقم موبايل مصري 11 رقماً" maxlength="11" />
                </div>
            </div>
            <div class="input-group">
                <label>البريد الإلكتروني</label>
                <input type="email" name="Email" placeholder="info@gmail.com"  maxlength="256" />
            </div>
            
            <div class="double-input">
                <div class="input-group file-upload">
                    <label for="nationalIdFront" id="nationalIdFrontLabel">
                            <i class="fa-solid fa-upload"></i> صورة وجه بطاقة الرقم القومي
                    </label>
                    <input type="file" id="nationalIdFront" name="NationalIdFront" accept="image/*" required />
                </div>
                <div class="input-group file-upload">
                    <label for="nationalIdBack" id="nationalIdBackLabel">
                            <i class="fa-solid fa-upload"></i> صورة ظهر بطاقة الرقم القومي
                    </label>
                    <input type="file" id="nationalIdBack" name="NationalIdBack" accept="image/*" required />
                </div>
            </div>

            <div class="input-group">
                <label>العنوان بالتفصيل</label>
                <input type="text" name="Address" placeholder="المحافظة - الحي - الشارع - رقم المبنى..." required maxlength="500" />
            </div>

            <div class="double-input">
                <div class="input-group">
                    <label>اختيار الموعد</label>
                    <input type="datetime-local" name="RequestedVisitAt" id="bookingRequestedVisitAt" required />
                </div>
                <div class="input-group">
                    <label>الحالة المرضية</label>
                    <input type="text" name="Condition" placeholder="اذكر الأعراض أو الحالة التي تحتاج رعاية..." required maxlength="2000" />
                </div>

            </div>

            <div class="input-group">
                <label>ملاحظات إضافية <span class="optional-label">(اختياري)</span></label>
                <textarea name="Notes" placeholder="أي معلومات إضافية تساعد الطبيب..." maxlength="4000"></textarea>
            </div>

            <div class="booking-form-footer">
                <button type="submit" class="submit-btn" id="bookingSubmitBtn">
                    طلب الآن
                </button>
                <a class="register-link" asp-area="Identity" asp-controller="Register" asp-action="Register">
                    إنشاء حساب | حتي لا تحتاج لتسجيل بيانتك في المرة القادمة
                </a>
            </div>
        </form>
    </div>
</div>

<div class="overlay " id="successOverlay">
    <div class="success-modal">
        <div class="success-icon">
            <i class="fa-solid fa-circle-check"></i>
        </div>
        <h2>تم إرسال طلبك بنجاح</h2>
        <p>طلبك مسجل الآن بحالة <strong>قيد الانتظار</strong>. سيتواصل معك أحد ممثلينا في أقرب وقت لتأكيد الزيارة.</p>
        <button class="submit-btn" onclick="closeSuccessModal()" style="margin-top:20px; width:auto; padding:10px 40px;">
            حسناً
        </button>
    </div>
</div>