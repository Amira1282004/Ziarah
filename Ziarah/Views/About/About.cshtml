@{
    ViewData["Title"] = "من نحن";
}
@section Styles {
    <link rel="stylesheet" href="~/css/Customer/about.css" />
}

@section Scripts {
    <script src="~/js/Customer/about.js"></script>
}
<section class="about-section">
    <div class="about-container">

        <div class="about-text-wrap">
            <h2>ما هي منصة زيارة؟</h2>
            <div class="line line-w"></div>
            <p>
                <strong>زيارة</strong> هي منصة رقمية متكاملة تهدف إلى تحسين جودة الخدمات الطبية وتيسير وصول المرضى إليها من خلال تقديم خدمة الزيارة الطبية المنزلية. تربط المنصة بين المرضى ونخبة من الأطباء والممرضين المتخصصين، مما يوفر الوقت والجهد وييسر الحصول على الرعاية الصحية اللازمة دون مغادرة المنزل.
            </p>
            <p>
                تتضمن المنصة أيضاً خدمة التأمين الطبي لأعضاء هيئة التدريس، وتوفر معلومات شاملة عن مراكز الأشعة والتحاليل والصيدليات المشاركة في برنامج التأمين.
            </p>
        </div>

        <div class="about-info">
            <div class="about-badge">
                مشروع تخرج لطلاب قسم تكنولوجيا التعليم كلية التربية النوعية جامعة الفيوم للعام الدراسي 2025 - 2026
            </div>

        </div>

    </div>
</section>


